# ============================================
# Instagram Order Agent - Environment Config
# ============================================

# --- META / INSTAGRAM ---
# From Meta Developer Console → Your App → Settings → Basic
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here

# Webhook verification token (you choose any string)
WEBHOOK_VERIFY_TOKEN=my_secret_verify_token_123

# Instagram Page Access Token (auto-refreshed by the app)
INSTAGRAM_ACCESS_TOKEN=your_long_lived_token_here

# Your Instagram Page ID (found in Meta Business Suite)
INSTAGRAM_PAGE_ID=your_page_id_here

# --- TELEGRAM NOTIFICATIONS ---
# Your Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# The shop owner's Telegram Chat ID (from @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here

# --- GOOGLE SHEETS ---
# The ID from your sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your_sheet_id_here

# Google Service Account email (from Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service@your-project.iam.gserviceaccount.com

# Google Service Account private key (paste the full key including \n)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"

# --- SERVER ---
PORT=3000
